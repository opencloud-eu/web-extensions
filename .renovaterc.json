{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "docker:pinDigests"],
  "prConcurrentLimit": 15,
  "postUpdateOptions": ["pnpmDedupe"],
  "packageRules": [
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "devDependencies (non-major)",
      "groupSlug": "dev-dependencies"
    },
    {
      "description": "Must stay on :latest — digest pinning breaks Woodpecker's privileged plugin allowlist matching (see https://codeberg.org/Codeberg-CI/feedback/issues/274)",
      "matchPackageNames": ["woodpeckerci/plugin-docker-buildx"],
      "enabled": false
    }
  ]
}
