{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "docker:pinDigests"],
  "prConcurrentLimit": 15,
  "postUpdateOptions": ["pnpmDedupe"],
  "packageRules": [
    {
      "matchManagers": ["npm"],
      "minimumReleaseAge": "12 hours"
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "devDependencies (non-major)",
      "groupSlug": "dev-dependencies"
    },
    {
      "description": "Must stay on :latest — digest pinning breaks Woodpecker's privileged plugin allowlist matching",
      "matchPackageNames": ["woodpeckerci/plugin-docker-buildx"],
      "enabled": false
    },
    {
      "matchPackageNames": ["@module-federation/vite", "@module-federation/runtime"],
      "enabled": false
    }
  ]
}
